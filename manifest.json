{
  "manifest_version": 3,
  "name": "X Banger Rescue",
  "version": "1.0.0",
  "description": "Captures recent X feed, so you can recover Tweets that disappeared",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://x.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/logo_16px.png",
    "32": "icons/logo_32px.png",
    "48": "icons/logo_48px.png",
    "128": "icons/logo_128px.png"
  },
  "content_scripts": [
    {
      "matches": [
        "https://x.com/*"
      ],
      "js": [
        "content-script.js"
      ],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "page-hook.js"
      ],
      "matches": [
        "https://x.com/*"
      ]
    }
  ],
  "action": {
    "default_title": "Open X Banger Rescue",
    "default_icon": {
      "16": "icons/logo_16px.png",
      "32": "icons/logo_32px.png",
      "48": "icons/logo_48px.png"
    }
  }
}
